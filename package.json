{
    "name": "tipstream-for-rumble-tether",
    "version": "2.0.0",
    "description": "AI-powered autonomous tipping agents for Rumble creators — Chrome sidebar extension powered by Tether WDK. Auto-tips based on watch time, chat hype NLP, viewer spikes, milestones, and smart splits. Real on-chain USDt + BTC.",
    "main": "src/background/service-worker.js",
    "author": "Aaditya Srivastava",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/sumionochi/tipstream.git"
    },
    "homepage": "https://github.com/sumionochi/tipstream#readme",
    "bugs": {
        "url": "https://github.com/sumionochi/tipstream/issues"
    },
    "keywords": [
        "rumble",
        "tether",
        "wdk",
        "tipping",
        "usdt",
        "btc",
        "chrome-extension",
        "ai-agent",
        "autonomous",
        "crypto",
        "evm",
        "bitcoin",
        "openclaw",
        "smart-splits",
        "hype-detection",
        "watch-time",
        "milestones",
        "gpt-4o-mini",
        "sidebar",
        "web3"
    ],
    "scripts": {
        "build": "webpack --config webpack.config.js",
        "watch": "webpack --config webpack.config.js --watch",
        "dev": "webpack --config webpack.config.js --mode development --watch"
    },
    "agents": {
        "skills": [
            {
                "name": "tipstream",
                "path": "./openclaw-skill"
            }
        ]
    },
    "dependencies": {
        "@tetherto/wdk": "latest",
        "@tetherto/wdk-wallet-btc": "^1.0.0-beta.7",
        "@tetherto/wdk-wallet-evm": "latest",
        "ethers": "^6.13.0"
    },
    "devDependencies": {
        "assert": "^2.1.0",
        "buffer": "^6.0.3",
        "crypto-browserify": "^3.12.0",
        "events": "^3.3.0",
        "https-browserify": "^1.0.0",
        "os-browserify": "^0.3.0",
        "path-browserify": "^1.0.1",
        "process": "^0.11.10",
        "sodium-javascript": "^0.8.0",
        "stream-browserify": "^3.0.0",
        "stream-http": "^3.2.0",
        "string_decoder": "^1.3.0",
        "url": "^0.11.3",
        "util": "^0.12.5",
        "vm-browserify": "^1.1.2",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.4"
    }
}
